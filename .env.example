# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (for admin operations - NEVER commit actual key!)
# Get from: Supabase Dashboard → Settings → API → service_role (secret)
# IMPORTANT: Only set this in Vercel/Netlify environment variables, NOT in .env for local dev
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 9router AI (for AI coaching features) — OpenAI-compatible, streaming
# IMPORTANT: Set VITE_9ROUTER_API_KEY in your hosting platform's environment
# variables (Vercel/Netlify). NEVER commit the actual key.
# Note: Vite inlines these at build time, so the key is visible in the client
# bundle. Guard the endpoint by domain/CORS or move behind a proxy for production.
VITE_9ROUTER_BASE_URL=https://9.viber.id/v1
VITE_9ROUTER_API_KEY=your_9router_api_key
# Optional: override the model (defaults to "weekly")
# VITE_9ROUTER_MODEL=weekly
